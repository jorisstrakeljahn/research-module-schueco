# Copy this file to ".env" and fill in values. NEVER commit the real .env.

# --- Database ---
# Local development uses the docker-compose Postgres (see docker-compose.yml).
DATABASE_URL=postgresql+psycopg://trendscout:trendscout@localhost:5433/trendscout

# --- Pipeline component selection ---
# embedder:   hashing (offline, no deps) | sentence_transformers (ml extra) | openai (llm extra)
# topic_model: simple (offline, sklearn) | bertopic (ml extra)
# describer:  template (offline) | openai (llm extra)
# classifier: heuristic (offline PESTEL/impact) | openai (LLM, JSON schema)
EMBEDDER=hashing
TOPIC_MODEL=simple
# Upper bound on number of topics/clusters per run (more -> finer niche topics)
TOPIC_MAX=12
DESCRIBER=template
CLASSIFIER=heuristic
# translator: auto (openai if key set, else off) | openai | none — on-demand DE/EN
TRANSLATOR=auto
# language of LLM-generated trend titles/summaries: en | de (UI can override per run)
LANGUAGE=en

# Embedding dimension. Must match the selected embedder.
#   hashing -> any (default 384) ; sentence_transformers (all-MiniLM) -> 384 ; openai text-embedding-3-small -> 1536
EMBEDDING_DIM=384

# --- Data sources (comma-separated) ---
# openalex      science publications (no key)
# arxiv         preprints, faster signals (no key)
# firecrawl     web/news market signals (needs FIRECRAWL_API_KEY)
# firecrawl_web web pages as weak signals (fast, noisier; needs FIRECRAWL_API_KEY)
# Weak-signal/news coverage: add firecrawl(,firecrawl_web) once the key below is set, e.g.:
#   SOURCES=openalex,arxiv,firecrawl
SOURCES=openalex

# --- Deep-research crawler (focused crawling / snowball sampling) ---
# expander:  none (offline) | openai (LLM query expansion)
# relevance: off | keyword (offline lexical gate) | openai (LLM relevance gate)
EXPANDER=none
RELEVANCE=off
RESEARCH_DOMAIN=building envelope and facade technology
RESEARCH_MAX_ROUNDS=2
RESEARCH_MAX_DOCS=80
RESEARCH_PER_QUERY_LIMIT=20
RESEARCH_EXPAND_TERMS=4
# Optional: override built-in domain seeds (comma-separated). Leave empty to use defaults.
SEED_TERMS=

# --- External APIs (only needed for non-offline components) ---
# OpenAlex requires no key, but a contact email enables the faster "polite pool".
OPENALEX_MAILTO=

# Needed only when EMBEDDER=openai or DESCRIBER=openai
OPENAI_API_KEY=

# Needed for the Firecrawl web/news/weak-signal connectors (firecrawl, firecrawl_web).
# Get a key at https://firecrawl.dev; once set, add firecrawl to SOURCES above.
FIRECRAWL_API_KEY=

# --- API auth ---
# Shared bearer token protecting state-changing routes (POST /runs, feedback,
# translate, reference-trends). Empty = auth disabled (fine for localhost).
# Set to a long random string for any non-local deployment; the frontend must send
# the same value via NEXT_PUBLIC_API_TOKEN.
API_TOKEN=
