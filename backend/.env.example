# Copy this file to ".env" and fill in values. NEVER commit the real .env.

# --- Database ---
# Local development uses the docker-compose Postgres (see docker-compose.yml).
DATABASE_URL=postgresql+psycopg://trendscout:trendscout@localhost:5433/trendscout

# --- Pipeline component selection ---
# embedder:   hashing (offline, no deps) | sentence_transformers (ml extra) | openai (llm extra)
# topic_model: simple (offline, sklearn) | bertopic (ml extra)
# describer:  template (offline) | openai (llm extra)
EMBEDDER=hashing
TOPIC_MODEL=simple
DESCRIBER=template

# Embedding dimension. Must match the selected embedder.
#   hashing -> any (default 384) ; sentence_transformers (all-MiniLM) -> 384 ; openai text-embedding-3-small -> 1536
EMBEDDING_DIM=384

# --- Data sources (comma-separated) ---
# openalex (science, no key) | arxiv (preprints, no key) | firecrawl (web/news, needs key)
SOURCES=openalex

# --- Deep-research crawler (focused crawling / snowball sampling) ---
# expander:  none (offline) | openai (LLM query expansion)
# relevance: off | keyword (offline lexical gate) | openai (LLM relevance gate)
EXPANDER=none
RELEVANCE=off
RESEARCH_DOMAIN=building envelope and facade technology
RESEARCH_MAX_ROUNDS=2
RESEARCH_MAX_DOCS=80
RESEARCH_PER_QUERY_LIMIT=20
RESEARCH_EXPAND_TERMS=4
# Optional: override built-in domain seeds (comma-separated). Leave empty to use defaults.
SEED_TERMS=

# --- External APIs (only needed for non-offline components) ---
# OpenAlex requires no key, but a contact email enables the faster "polite pool".
OPENALEX_MAILTO=

# Needed only when EMBEDDER=openai or DESCRIBER=openai
OPENAI_API_KEY=

# Needed only for the Firecrawl-based web/news connector (added after v0)
FIRECRAWL_API_KEY=
