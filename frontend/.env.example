# Copy this file to ".env.local" and adjust. NEVER commit the real .env.local.

# Base URL of the trendscout backend API.
NEXT_PUBLIC_API_BASE=http://127.0.0.1:8000

# Shared bearer token for state-changing requests; must match the backend API_TOKEN.
# Leave empty for local development (backend auth disabled).
# NOTE: a NEXT_PUBLIC_ value is shipped to the browser and visible to any UI user.
# It gates casual/remote abuse only, not a determined user of the demo UI — an
# accepted trade-off for this prototype. Use a server-side proxy for real auth.
NEXT_PUBLIC_API_TOKEN=
