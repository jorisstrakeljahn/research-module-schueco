# Copy this file to ".env.local" and adjust. NEVER commit the real .env.local.

# Base URL of the trendscout backend API.
NEXT_PUBLIC_API_BASE=http://127.0.0.1:8000

# Server-only settings used by the Next.js BFF for state-changing requests.
# API_BASE defaults to NEXT_PUBLIC_API_BASE. API_TOKEN must never be NEXT_PUBLIC.
API_BASE=http://127.0.0.1:8000
API_TOKEN=
